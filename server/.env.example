# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGO_URL=mongodb://localhost:27017/filego

# Authentication
JWT_SECRET=your_32_character_long_jwt_secret_here
JWT_REFRESH_SECRET=your_32_character_long_refresh_secret_here

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your_bucket_name

# Client (Used for CORS and redirects)
CLIENT_URL=http://localhost:5173

# Better Stack (Observability & Logging)
BETTER_STACK_SOURCE_TOKEN=your_logtail_source_token_here
